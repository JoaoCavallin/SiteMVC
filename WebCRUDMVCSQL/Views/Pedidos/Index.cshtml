@model IEnumerable<WebCRUDMVCSQL.Models.Pedido>
@{
    ViewData["Title"] = "Index";
}
<h1>Pedidos</h1>
<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Cliente.Nome)</th>
            <th>@Html.DisplayNameFor(model => model.Data)</th>
            <th>Total de Itens</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Cliente.Nome)</td>
                <td>@item.Data.ToString("dd/MM/yyyy")</td>
                <td>@item.Itens?.Count</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
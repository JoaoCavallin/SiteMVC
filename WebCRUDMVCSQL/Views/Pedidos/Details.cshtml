@model WebCRUDMVCSQL.Models.Pedido
@{
    ViewData["Title"] = "Details";
}
<h1>Details</h1>
<div>
    <h4>Pedido</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Cliente</dt>
        <dd class="col-sm-10">@Model.Cliente?.Nome</dd>

        <dt class="col-sm-2">Data</dt>
        <dd class="col-sm-10">@Model.Data.ToString("dd/MM/yyyy")</dd>
    </dl>

    <h5>Itens do Pedido</h5>
    <table class="table">
        <thead>
            <tr>
                <th>Produto</th>
                <th>Preço Unit.</th>
                <th>Quantidade</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Itens)
            {
                <tr>
                    <td>@item.Produto?.Nome</td>
                    <td>R$ @item.Produto?.Preco</td>
                    <td>@item.Quantidade</td>
                    <td>R$ @(item.Produto?.Preco * item.Quantidade)</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>